# Copy to .env next to docker-compose.yml for local overrides.
# JWT: openssl rand -base64 48
JWT_SECRET=change-me-use-openssl-rand-base64-48-for-production

# MQTT (must match services/broker/passwd — regenerate both if you change password)
MQTT_USER=home
MQTT_PASSWORD=home-dev-change-me

IOT_AUTH_USERNAME=admin
# Generate hash: cd ../services/iot-api && npm run hash-password -- 'your-password'
IOT_AUTH_PASSWORD_HASH= admin123
