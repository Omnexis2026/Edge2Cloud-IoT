PORT=4010
NODE_ENV=production

# Generate: cd services/iot-api && npm run hash-password -- 'your-strong-password'
IOT_AUTH_USERNAME=admin
IOT_AUTH_PASSWORD_HASH=

# openssl rand -base64 48
JWT_SECRET=

# Optional: e.g. 12h
# JWT_EXPIRES_IN=12h

# HTTPS sites: cookies only sent over TLS
COOKIE_SECURE=true

# Optional: public site URL (documentation / future use)
# PUBLIC_ORIGIN=https://miodethereal.com

# Path to built React app (default: ./public in Docker, or ../../apps/iot-web/dist locally)
# IOT_WEB_DIST=
