PORT=3000
# Either set MQTT_URL, or MQTT_HOST + MQTT_PORT + MQTT_USER + MQTT_PASSWORD
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=home
MQTT_PASSWORD=home-dev-change-me
# MQTT_URL=mqtt://home:home-dev-change-me@127.0.0.1:1883
# Wildcards aligned with firmware/esp32 (home/{homeId}/device/{deviceId}/…)
# MQTT_TOPIC_TELEMETRY=home/+/device/+/telemetry
# MQTT_TOPIC_STATE=home/+/device/+/state
# SQLite persistence (default ./data/telemetry.db)
# SQLITE_PATH=./data/telemetry.db
# MQTT_DB_MAX_ROWS=50000
